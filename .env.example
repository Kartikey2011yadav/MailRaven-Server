# MailRaven Docker Environment Variables
# Copy this file to .env and set real values before deploying.

# PostgreSQL
POSTGRES_USER=mailraven
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=mailraven

# MailRaven (these override config.yaml values)
# MAILRAVEN_DOMAIN=mail.example.com
# MAILRAVEN_SMTP_HOSTNAME=mail.example.com
# MAILRAVEN_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
# MAILRAVEN_CORS_ORIGINS=https://mail.example.com
# MAILRAVEN_STORAGE_BLOB_PATH=/data/blobs
# MAILRAVEN_DKIM_KEY_PATH=/data/dkim/private.key
