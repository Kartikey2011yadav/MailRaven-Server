#!/bin/sh
# Pre-commit hook: runs lint, type checks, and build before allowing a commit.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "Running pre-commit checks..."

# Create dummy frontend assets if dist/ is empty (needed for go build)
mkdir -p internal/adapters/http/static/dist
touch internal/adapters/http/static/dist/.gitkeep

# 1. Go checks
echo "==> Go vet..."
go vet ./...

echo "==> Go build..."
go build ./...

# 2. golangci-lint (optional, skip if not installed)
if command -v golangci-lint >/dev/null 2>&1; then
    echo "==> golangci-lint..."
    golangci-lint run --timeout=5m ./...
else
    echo "==> golangci-lint not installed, skipping (install v2+ for Go 1.25 support)"
fi

# 3. Frontend checks
echo "==> Frontend TypeScript type check..."
(cd client && npx tsc -b)

echo "==> Frontend lint..."
(cd client && npx eslint . --max-warnings 5)

echo "All pre-commit checks passed."
exit 0
